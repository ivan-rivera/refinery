{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "just test",
            "group": { "kind": "test", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        },
        {
            "label": "Run Linter",
            "type": "shell",
            "command": "just lint",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": []
        },
        {
            "label": "Check API Health",
            "type": "shell",
            "command": "curl -i localhost:8000/api/v1/health",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "group": { "kind": "test", "isDefault": false }
        },
        {
            "label": "Run Server",
            "type": "shell",
            "command": "uv run uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            },
            "group": { "kind": "build", "isDefault": false }
        }
    ]
}
